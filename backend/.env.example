MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/canteenDB
FLASK_ENV=production
# Local only. Do not add PORT in Vercel — the platform already defines it and will error if you duplicate it.
PORT=5000
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://example.com
# Vercel multi-service: leave unset (defaults to /_/backend when VERCEL=1). Local: leave unset.
# API_URL_PREFIX=
